# sibur-reestr-bot — шаблон переменных окружения
# Скопируй в .env и заполни реальными значениями

# Telegram-бот (@sibur_reestr_bot)
REESTR_BOT_TOKEN=

# Список user IDs через запятую, кому разрешено; пусто = никому
ALLOWED_USERS=

# Anthropic Claude API
CLAUDE_API_KEY=

# SberCRM
SBERCRM_EMAIL=
SBERCRM_PASSWORD=

# Рабочая папка (опционально, default /tmp/reestr-bot)
# TEMP_DIR=/tmp/reestr-bot
